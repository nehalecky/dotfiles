{
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(uv:*)",
      "Bash(find:*)",
      "Bash(mv:*)",
      "Bash(grep:*)",
      "Bash(npm:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Write",
      "Edit",
      "Bash(chmod:*)",
      "Bash(touch:*)"
    ],
    "deny": []
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true,
    "elements-of-style@superpowers-marketplace": true,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run {{ .chezmoi.homeDir }}/.claude/hooks/stop.py --notify"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run {{ .chezmoi.homeDir }}/.claude/hooks/notification.py --notify"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run {{ .chezmoi.homeDir }}/.claude/hooks/subagent_stop.py --notify"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run {{ .chezmoi.homeDir }}/.claude/hooks/session_start.py --announce --load-context"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run {{ .chezmoi.homeDir }}/.claude/hooks/pre_compact.py --backup"
          }
        ]
      }
    ]
  }
{{ if eq .profile "work" }},
  "mcpServers": {
    "incident-io": {
      "type": "http",
      "url": "https://mcp.incident.io/mcp"
    }
  }{{ end }}
}
