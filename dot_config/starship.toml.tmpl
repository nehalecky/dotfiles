"$schema" = 'https://starship.rs/config-schema.json'

# Starship Configuration вАФ Tokyo Night preset
# Profile: {{ .profile }}
# Managed by chezmoi вАФ do not edit directly

format = """
[вЦСвЦТвЦУ](#a3aed2)\
[ оЬС ](bg:#a3aed2 fg:#090c0c)\
[оВі](bg:#769ff0 fg:#a3aed2)\
$directory\
[оВі](fg:#769ff0 bg:#394260)\
$git_branch\
$git_status\
[оВі](fg:#394260 bg:#212736)\
$nodejs\
$rust\
$golang\
$php\
[оВі](fg:#212736 bg:#1d2230)\
$time\
[оВі ](fg:#1d2230)\
\n$character"""

[directory]
{{ if eq .profile "work" -}}
style = "bold blue"
{{ else -}}
style = "fg:#e3e5e5 bg:#769ff0"
{{ end -}}
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "вА¶/"

[directory.substitutions]
"Documents" = "у∞ИЩ "
"Downloads" = "пАЩ "
"Music" = "пАБ "
"Pictures" = "пАЊ "
{{ if eq .profile "personal" -}}
"~/Projects" = "пБЉ "
"~/Code" = "оЮЦ "
"~/Documents/Writing" = "пЗЙ "
"~/Photos" = "пАЊ "
{{ end -}}

[git_branch]
symbol = "пРШ"
{{ if eq .profile "work" -}}
style = "bold purple"
{{ else -}}
style = "bg:#394260"
{{ end -}}
format = '[[ пРШ $branch ](fg:#769ff0 bg:#394260)]($style)'

[git_status]
style = "bg:#394260"
format = '[[($all_status$ahead_behind )](fg:#769ff0 bg:#394260)]($style)'

[nodejs]
symbol = "оЬШ"
style = "bg:#212736"
format = '[[ оЬШ ($version) ](fg:#769ff0 bg:#212736)]($style)'

[rust]
symbol = "оЮ®"
style = "bg:#212736"
format = '[[ оЮ® ($version) ](fg:#769ff0 bg:#212736)]($style)'

[golang]
symbol = "оШІ"
style = "bg:#212736"
format = '[[ оШІ ($version) ](fg:#769ff0 bg:#212736)]($style)'

[php]
symbol = "оШИ"
style = "bg:#212736"
format = '[[ оШИ ($version) ](fg:#769ff0 bg:#212736)]($style)'

[time]
disabled = false
time_format = "%R"
style = "bg:#1d2230"
format = '[[ пРЇ $time ](fg:#a0a9cb bg:#1d2230)]($style)'

{{ if eq .profile "personal" -}}
[kubernetes]
disabled = true

[aws]
disabled = true

[gcloud]
disabled = true

[battery]
full_symbol = "рЯФЛ"
charging_symbol = "вЪ°"
discharging_symbol = "рЯТА"

[[battery.display]]
threshold = 20
style = "bold red"
{{ else -}}
[kubernetes]
disabled = false
format = 'on [$symbol$context( \\($namespace\\))]($style) '
symbol = "вШЄ "
style = "bold blue"

[aws]
disabled = false
format = 'on [$symbol($profile )(\\($region\\) )]($style)'
symbol = "пЙ∞ "
style = "bold orange"

[hostname]
ssh_only = false
format = "[$hostname]($style) "
style = "bold dimmed green"
disabled = false
{{ end -}}
