# Git Configuration
# Managed by chezmoi

[user]
    name = {{ .git_name }}
    email = {{ .git_email }}

[commit]
    gpgsign = true

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

{{- if .git_signing_key }}
[user]
    signingkey = {{ .git_signing_key }}
{{- end }}

[init]
    defaultBranch = main

[pull]
    rebase = false

[core]
    editor = code --wait
