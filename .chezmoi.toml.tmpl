{{- /* ── Profile Selection ─────────────────────────────────── */ -}}
{{- /* Using promptStringOnce (not promptChoiceOnce) so input waits for Enter */ -}}
{{- $profile := promptStringOnce . "profile" "Machine profile (personal/work)" "personal" -}}
{{- if not (has $profile (list "personal" "work")) -}}
{{-   fail (printf "Invalid profile: %q — must be 'personal' or 'work'. Re-run chezmoi init." $profile) -}}
{{- end -}}

{{- /* ── Terminal ─────────────────────────────────────────────── */ -}}
{{- $validTerminals := list "wezterm" "iterm2" "ghostty" "kitty" "alacritty" "default" -}}
{{- $terminal := promptStringOnce . "terminal" "Terminal emulator (wezterm/iterm2/ghostty/kitty/alacritty/default)" "wezterm" -}}
{{- if not (has $terminal $validTerminals) -}}
{{-   fail (printf "Invalid terminal: %q — must be one of: %s. Re-run chezmoi init." $terminal ($validTerminals | join ", ")) -}}
{{- end -}}

{{- /* ── Identity ──────────────────────────────────────────── */ -}}
{{- $git_name := promptStringOnce . "git_name" "Git author name" "Nicholaus Halecky" -}}
{{- $preferred_name := promptStringOnce . "preferred_name" "Preferred/casual name" (index (splitList " " $git_name) 0) -}}
{{- $git_email := "" -}}
{{- $github_username := "" -}}
{{- if eq $profile "personal" -}}
{{-   $git_email = promptStringOnce . "git_email" "Git email" "nehalecky@gmail.com" -}}
{{-   $github_username = promptStringOnce . "github_username" "GitHub username" "nehalecky" -}}
{{- else -}}
{{-   $git_email = promptStringOnce . "git_email" "Work git email" "user@company.com" -}}
{{-   $github_username = promptStringOnce . "github_username" "Work GitHub username" "" -}}
{{- end -}}

{{- /* ── SSH & Signing ─────────────────────────────────────── */ -}}
{{- $git_signing_key := "" -}}
{{- $op_auth_key_name := "" -}}
{{- $op_signing_key_name := "" -}}
{{- if eq $profile "personal" -}}
{{-   $git_signing_key = promptStringOnce . "git_signing_key" "Git signing public key" "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGfxtbZHZuHkiMv2ZXR52KSwROrTXK0wyxoX8yd88Ih6" -}}
{{-   $op_auth_key_name = promptStringOnce . "op_auth_key_name" "1Password SSH auth key name (1Password > SSH Key category > exact item title)" "" -}}
{{-   $op_signing_key_name = promptStringOnce . "op_signing_key_name" "1Password signing key name (1Password > SSH Key category > exact item title)" "" -}}
{{- else -}}
{{-   $git_signing_key = promptStringOnce . "git_signing_key" "Work git signing public key (ssh-ed25519 ...)" "" -}}
{{-   $op_auth_key_name = promptStringOnce . "op_auth_key_name" "1Password SSH auth key name" "GitHub Auth Key" -}}
{{-   $op_signing_key_name = promptStringOnce . "op_signing_key_name" "1Password signing key name" "Signing Key" -}}
{{- end -}}

[data]
    profile             = {{ $profile | quote }}
    isWork              = {{ eq $profile "work" }}
    isPersonal          = {{ eq $profile "personal" }}
    terminal            = {{ $terminal | quote }}
    isWezTerm           = {{ eq $terminal "wezterm" }}
    isITerm2            = {{ eq $terminal "iterm2" }}
    git_name            = {{ $git_name | quote }}
    preferred_name      = {{ $preferred_name | quote }}
    git_email           = {{ $git_email | quote }}
    github_username     = {{ $github_username | quote }}
    git_signing_key     = {{ $git_signing_key | quote }}
    op_auth_key_name    = {{ $op_auth_key_name | quote }}
    op_signing_key_name = {{ $op_signing_key_name | quote }}
