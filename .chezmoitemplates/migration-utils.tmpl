# =============================================================================
# Migration utility — inlined by chezmoi templates into run_* scripts.
# Any script using this becomes a .tmpl file; chezmoi renders it before execution.
# Tests: tests/chezmoiscripts/test_migration.py
# =============================================================================
from __future__ import annotations

import os
import sys
from dataclasses import dataclass, field
from pathlib import Path
from typing import Callable


@dataclass
class ConfigItem:
    """A configuration location to audit and optionally migrate during tool migration."""

    path: Path | str
    description: str
    compatible: bool = True          # True = confirm compatible as-is, False = needs attention
    migrate_fn: Callable | None = None
    migrate_description: str = ""


def migration_prompt(
    tool: str,
    current_binary: str | None,
    expected_path: Path,
    current_source: str,
    expected_source: str,
    install_fn: Callable,
    config_items: list[ConfigItem] | None = None,
    cleanup_hints: list[str] | None = None,
    post_migration_notes: list[str] | None = None,
) -> None:
    """Detect installation state and guide the user through migration if needed.

    Three cases:
      1. Not installed → install directly.
      2. Already at expected_path → nothing to do.
      3. Installed via different method → show full migration report, prompt.
    """
    config_items = config_items or []
    cleanup_hints = cleanup_hints or []
    post_migration_notes = post_migration_notes or []

    # Case 1: not installed
    if current_binary is None:
        print(f"🤖 {tool} not found — installing via {expected_source}...")
        install_fn()
        return

    # Case 2: already at the right place
    try:
        already_correct = Path(current_binary).resolve() == Path(expected_path).resolve()
    except (OSError, ValueError):
        already_correct = False

    if already_correct:
        print(f"✅ {tool} already installed via {expected_source} ({expected_path})")
        return

    # Case 3: installed via a different method — show migration report
    print(f"\n⚠️  Migration available: {tool}")
    print(f"   Currently: {current_source} → {current_binary}")
    print(f"   dotfiles now use: {expected_source} → {expected_path}")

    if config_items:
        print("\n   Configuration review:")
        for item in config_items:
            p = Path(str(item.path)).expanduser()
            if not p.exists():
                print(f"   ➖ {item.path} — not present, nothing to migrate")
            elif item.compatible:
                print(f"   ✅ {item.path} — {item.description}, compatible as-is")
            else:
                print(f"   ⚠️  {item.path} — {item.description}, needs attention")
                if item.migrate_fn and item.migrate_description:
                    print(f"         → auto-migration available: {item.migrate_description}")

    if cleanup_hints:
        print("\n   Cleanup after migrating:")
        for hint in cleanup_hints:
            print(f"   ℹ️  {hint}")

    if post_migration_notes:
        print("\n   After migrating:")
        for note in post_migration_notes:
            print(f"   • {note}")

    print()

    auto = os.environ.get("CHEZMOI_AUTO_MIGRATE") == "1"
    interactive = sys.stdin.isatty()

    if auto:
        print("   CHEZMOI_AUTO_MIGRATE=1 — proceeding with migration...")
        _perform_migration(config_items, install_fn)
        return

    if not interactive:
        print(
            "   Non-interactive session detected. To migrate:\n"
            "   • Run `chezmoi apply` in an interactive terminal, or\n"
            "   • Set CHEZMOI_AUTO_MIGRATE=1 and run `chezmoi apply`\n"
            f"   Keeping existing {tool} installation for now."
        )
        return

    answer = input("   Migrate now? [y/N]: ").strip().lower()
    if answer == "y":
        _perform_migration(config_items, install_fn)
    else:
        print(f"   Keeping existing {tool} installation.")


def _perform_migration(config_items: list[ConfigItem], install_fn: Callable) -> None:
    for item in config_items:
        if item.migrate_fn and not item.compatible:
            p = Path(str(item.path)).expanduser()
            if p.exists():
                print(f"   🔄 Migrating {item.path}...")
                item.migrate_fn()
    install_fn()
    print("✅ Migration complete.")
