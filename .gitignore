# Logs and runtime state (never version these)
logs/
*.log

# Backup files (never version these)
*.backup
*.bak
*~

# Temporary files
*.tmp
*.temp

# Python bytecode
__pycache__/
*.pyc

# OS-specific files
.DS_Store
Thumbs.db

# Editor artifacts
*.swp
*.swo
*~
.vscode/settings.json.local

# Local development artifacts
test_*.sh
test-*.py
test*.py

# CI tests are tracked (override test* patterns)
!tests/
!tests/**
tests/__pycache__/

# Go workspace (if using local development)
go/