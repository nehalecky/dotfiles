{{/* Pull strata layers in order — lower index = lower priority, higher index overrides.
     strata_layers is a comma-separated list of SSH git URLs. */}}
{{- $layers := list -}}
{{- if and (hasKey . "strata_layers") .strata_layers -}}
{{-   $layers = splitList "," .strata_layers | compact -}}
{{- end -}}
{{- range $i, $url := $layers }}
.strata_layer_{{ $i }}/:
  type: git
  url: "{{ $url | trim }}"
  refreshPeriod: "168h"
{{ end -}}
