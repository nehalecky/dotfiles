#!/usr/bin/env python3
# Install all packages from Brewfile after Homebrew is available.
# Re-runs automatically when the Brewfile changes.
#
# Brewfile hash: {{ include "dot_Brewfile.tmpl" | sha256sum }}
import shutil
import subprocess
import sys
from pathlib import Path

ESSENTIAL_TOOLS = ["rg", "fd", "eza", "bat", "delta", "yazi", "lazygit", "gh", "glow"]


def find_brew() -> str | None:
    if shutil.which("brew"):
        return "brew"
    for path in ("/opt/homebrew/bin/brew", "/usr/local/bin/brew"):
        if Path(path).exists():
            return path
    return None


def main() -> None:
    print("📦 Installing packages from Brewfile...")

    brew = find_brew()
    if not brew:
        print("❌ Cannot find Homebrew installation", file=sys.stderr)
        sys.exit(1)
    print("✅ Homebrew found, proceeding with package installation")

    brewfile = Path.home() / ".Brewfile"
    if not brewfile.exists():
        print(f"❌ Brewfile not found at {brewfile}", file=sys.stderr)
        print("💡 Brewfile should be deployed before this script runs")
        sys.exit(1)

    print("📋 Found Brewfile, installing packages...")
    result = subprocess.run([brew, "bundle", "--global"], cwd=Path.home())
    if result.returncode != 0:
        print("⚠️  Some packages failed to install. Run 'brew bundle --global' to retry.")
    print("✅ Package installation complete")

    print("🔍 Verifying essential tools...")
    missing = [t for t in ESSENTIAL_TOOLS if not shutil.which(t)]
    for tool in ESSENTIAL_TOOLS:
        status = "✅" if tool not in missing else "❌"
        print(f"{status} {tool}")

    if not missing:
        print("✨ All essential development tools are ready!")
    else:
        print(f"⚠️  {len(missing)} essential tool(s) missing")


if __name__ == "__main__":
    main()
