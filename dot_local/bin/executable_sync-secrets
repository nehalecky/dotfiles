#!/usr/bin/env python3
"""Sync secrets from 1Password to age-encrypted files for fallback deployment.

This maintains 1Password as the canonical source while enabling deployment
to environments without 1Password access.
"""
import os
import shutil
import subprocess
import sys
from pathlib import Path

GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
RESET = "\033[0m"

# Define secrets to sync: list of (filename, 1password-reference) tuples.
# Uncomment and modify as needed:
SECRETS: list[tuple[str, str]] = [
    # ("github-token", "op://Personal/GitHub/personal-access-token"),
    # ("openai-key",   "op://Personal/OpenAI/api-key"),
    # ("aws-access-key", "op://Work/AWS/access-key-id"),
    # ("aws-secret-key", "op://Work/AWS/secret-access-key"),
]


def run(*cmd: str, **kw) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, **kw)


def ensure_age() -> None:
    if not shutil.which("age"):
        print(f"{YELLOW}Warning: age not found, installing...{RESET}")
        run("brew", "install", "age", check=True)


def ensure_op_signed_in() -> None:
    """Sign in to 1Password if not already authenticated."""
    if run("op", "account", "list", capture_output=True).returncode == 0:
        return
    print("Please sign in to 1Password...")
    signin = run("op", "signin", capture_output=True, text=True)
    # Parse exported env vars and inject into the current process so
    # subsequent op calls inherit the session token.
    for line in signin.stdout.splitlines():
        if line.startswith("export "):
            key, _, value = line[7:].partition("=")
            os.environ[key] = value.strip('"')


def main() -> None:
    print("🔐 Syncing secrets from 1Password to encrypted fallback files...")

    if not shutil.which("op"):
        print(f"{RED}Error: 1Password CLI (op) not found{RESET}")
        print("Install with: brew install --cask 1password-cli")
        sys.exit(1)

    ensure_age()

    source_path = run(
        "chezmoi", "source-path", capture_output=True, text=True, check=True
    ).stdout.strip()
    secrets_dir = Path(source_path) / ".secrets"
    secrets_dir.mkdir(exist_ok=True)

    ensure_op_signed_in()

    synced = failed = 0

    for filename, op_ref in SECRETS:
        print(f"Syncing {filename}... ", end="", flush=True)

        op_result = run("op", "read", op_ref, capture_output=True)
        if op_result.returncode != 0:
            print(f"{RED}✗ Failed{RESET}")
            print(f"{RED}  Could not read from: {op_ref}{RESET}")
            failed += 1
            continue

        age_result = run(
            "age", "--encrypt", "--armor",
            input=op_result.stdout,
            capture_output=True,
        )
        if age_result.returncode != 0:
            print(f"{RED}✗ Failed{RESET}")
            failed += 1
            continue

        (secrets_dir / f"{filename}.age").write_bytes(age_result.stdout)
        print(f"{GREEN}✓{RESET}")
        synced += 1

    print()
    print("Sync complete:")
    print(f"  {GREEN}✓ Synced: {synced}{RESET}")
    if failed:
        print(f"  {RED}✗ Failed: {failed}{RESET}")
    else:
        print(f"  {GREEN}✓ All secrets synced successfully!{RESET}")

    if synced:
        print()
        print("📝 Next steps:")
        print("1. Test decryption: cat .secrets/FILENAME.age | age --decrypt")
        print("2. Add to git: chezmoi git add .secrets/")
        print("3. Commit: chezmoi git commit -m 'Update encrypted secrets'")


if __name__ == "__main__":
    main()
