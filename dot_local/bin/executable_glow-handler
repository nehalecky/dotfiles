#!/bin/bash
# Open a markdown file in a glow pane

FILE="$1"
FILE="${FILE#file://}"  # Remove file:// prefix if present

if [[ -z "$FILE" ]]; then
  echo "Usage: glow-handler <file>" >&2
  exit 1
fi

# Open in a new right-side pane if inside zellij, otherwise fall back
if command -v zellij >/dev/null 2>&1 && [[ -n "${ZELLIJ:-}" ]]; then
  exec zellij action new-pane --direction right --close-on-exit -- glow "$FILE"
else
  exec glow "$FILE"
fi
