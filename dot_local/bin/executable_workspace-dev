#!/bin/bash
# Dev workspace — launch or attach to a named project session
# Usage: workspace-dev [project-name]
#   In a project directory:  workspace-dev
#   From anywhere:           workspace-dev myproject

set -euo pipefail

PROJECT_NAME=${1:-$(basename "$PWD")}
PROJECT_DIR=${PROJECT_DIR:-$PWD}

# Guard: HOME directory with no explicit name is ambiguous
if [[ "$PROJECT_DIR" == "$HOME" ]] && [[ -z "${1:-}" ]]; then
  echo "⚠️  No project detected in HOME directory"
  echo ""
  echo "Options:"
  echo "  workspace-home               Launch Home Command Center"
  echo "  workspace-dev <name>         Create named workspace here"
  echo "  cd /path/to/project && workspace-dev"
  exit 0
fi

SESSION="dev-$PROJECT_NAME"

# Attach to existing session if available
if zellij list-sessions --short 2>/dev/null | grep -qx "$SESSION"; then
  echo "💻 Attaching to existing $PROJECT_NAME workspace..."
  exec zellij attach "$SESSION"
fi

echo "🚀 Launching workspace: $PROJECT_NAME"
echo "📁 Directory: $PROJECT_DIR"

# Detect and announce project type
if [[ -f "$PROJECT_DIR/pyproject.toml" ]]; then
  echo "🐍 Python project (uv managed)"
elif [[ -f "$PROJECT_DIR/package.json" ]]; then
  echo "📦 Node.js project"
elif [[ -f "$PROJECT_DIR/Cargo.toml" ]]; then
  echo "🦀 Rust project"
elif [[ -f "$PROJECT_DIR/go.mod" ]]; then
  echo "🐹 Go project"
fi

cd "$PROJECT_DIR"
exec zellij --session "$SESSION" --layout dev
