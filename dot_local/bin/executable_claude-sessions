#!/usr/bin/env python3
"""Browse and resume Claude Code sessions.

Lists sessions sorted by most-recently-modified, with agent name,
modification date, todo progress, and a preview of the first prompt.
"""
import json
import sys
from datetime import datetime
from pathlib import Path

CLAUDE_DIR = Path.home() / ".claude"
SESSIONS_DIR = CLAUDE_DIR / "data" / "sessions"
TODOS_DIR = CLAUDE_DIR / "todos"

# Column widths matching the original layout
COL = {"id": 8, "agent": 12, "date": 16, "progress": 15, "prompt": 63}


def get_todo_info(session_id: str) -> str:
    if not TODOS_DIR.exists():
        return "No todos"
    todo_files = list(TODOS_DIR.glob(f"*{session_id}*"))
    if not todo_files:
        return "No todos"

    total = completed = 0
    for f in todo_files:
        if not f.is_file() or f.stat().st_size <= 10:
            continue
        try:
            for item in json.loads(f.read_text()):
                if "status" in item:
                    total += 1
                    if item["status"] == "completed":
                        completed += 1
        except (json.JSONDecodeError, TypeError):
            continue

    return f"{completed}/{total} todos" if total else "Empty todos"


def get_session_summary(session_file: Path) -> str | None:
    session_id = session_file.stem
    try:
        data = json.loads(session_file.read_text())
    except (json.JSONDecodeError, OSError):
        return None

    agent_name = data.get("agent_name", "Unknown")
    prompts = data.get("prompts", [])
    raw_first = str(prompts[0]) if prompts else "No prompts"
    first_prompt = (raw_first[:60] + "...") if len(raw_first) > 60 else raw_first

    modified = datetime.fromtimestamp(session_file.stat().st_mtime).strftime(
        "%Y-%m-%d %H:%M"
    )
    todo_info = get_todo_info(session_id)

    c = COL
    return (
        f"{session_id[:c['id']]:<{c['id']}} │ "
        f"{agent_name:<{c['agent']}} │ "
        f"{modified:<{c['date']}} │ "
        f"{todo_info:<{c['progress']}} │ "
        f"{first_prompt:<{c['prompt']}} │ "
        f"{session_id}"
    )


def main() -> None:
    print("🔍 Claude Code Session Browser")
    print("================================")

    if not CLAUDE_DIR.exists():
        print(f"❌ Claude directory not found at {CLAUDE_DIR}")
        sys.exit(1)

    if not SESSIONS_DIR.exists() or not any(SESSIONS_DIR.glob("*.json")):
        print(f"📭 No sessions found in {SESSIONS_DIR}")
        sys.exit(0)

    c = COL
    print(
        f"{'SHORT-ID':<{c['id']}} │ {'AGENT':<{c['agent']}} │ "
        f"{'MODIFIED':<{c['date']}} │ {'PROGRESS':<{c['progress']}} │ "
        f"{'FIRST PROMPT':<{c['prompt']}} │ FULL SESSION ID"
    )
    # Separator mirrors original bash layout exactly
    print(
        "─" * (c["id"] + 1) + "┼" +
        "─" * (c["agent"] + 2) + "┼" +
        "─" * (c["date"] + 2) + "┼" +
        "─" * (c["progress"] + 2) + "┼" +
        "─" * (c["prompt"] + 2) + "┼" +
        "─" * 40
    )

    sessions = sorted(
        SESSIONS_DIR.glob("*.json"),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    for session_file in sessions:
        summary = get_session_summary(session_file)
        if summary:
            print(summary)

    print()
    print("💡 Usage:")
    print("   claude --continue                              # Resume most recent session")
    print("   claude --resume                                # Interactive session selector")
    print("   claude --resume <session-id>                   # Resume specific session")
    print(
        r"   claude --resume $(claude-sessions | tail -n +4 | head -1 | awk '{print $NF}')"
        "  # Resume newest"
    )


if __name__ == "__main__":
    main()
