#!/bin/bash
# Home Command Center — persistent daily operations workspace
# Attaches to an existing session or creates a new one with the home layout.

set -euo pipefail

SESSION="home"

if zellij list-sessions --short 2>/dev/null | grep -qx "$SESSION"; then
  echo "🏠 Attaching to existing Home Command Center..."
  exec zellij attach "$SESSION"
fi

echo "🏠 Launching Home Command Center..."
cd "$HOME"
exec zellij --session "$SESSION" --layout home
